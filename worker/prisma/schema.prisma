generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  reviews   Review[]
}

model Review {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  code       String       @db.Text
  language   String
  status     ReviewStatus @default(PENDING)
  result     String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId])
}

enum ReviewStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

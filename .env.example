# ─── Database ─────────────────────────────────────
POSTGRES_USER=kritique
POSTGRES_PASSWORD=kritique_secret
POSTGRES_DB=kritique_db
DATABASE_URL="postgresql://kritique:kritique_secret@postgres:5432/kritique_db"

# ─── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ─────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars

# ─── Gemini ───────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── App ──────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
